#!/bin/sh
# Run busybox ntpd as a long-running daemon. On boards without a
# battery-backed RTC (Raspberry Pi, etc.) the clock starts at the epoch
# (1970); ntpd steps it to real time on first successful sync. Services
# that start before that brief window will see 1970 in their early log
# lines, but the clock catches up automatically. We intentionally do
# not block boot here — a one-shot pre-sync is fragile (DNS races right
# after udhcpc, transient peer failures) and the daemon handles both
# the initial step and ongoing drift correction.

PEERS="-p pool.ntp.org -p time.cloudflare.com -p time.google.com"

case "$1" in
    start)
        # busybox installs ntpd as /usr/sbin/ntpd; rely on PATH so this
        # works regardless of where the applet symlink lands. The daemon
        # backgrounds itself when -n is omitted.
        ntpd $PEERS 2>/dev/null
        ;;
    stop)
        killall ntpd 2>/dev/null
        ;;
esac
