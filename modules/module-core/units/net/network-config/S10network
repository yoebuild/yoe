#!/bin/sh
ip link set lo up
ip link set eth0 up

# Wait briefly for carrier so the DHCP client doesn't immediately hit
# "Network is down" on virtio-net and similar drivers where IFF_LOWER_UP
# lags IFF_UP.
i=0
while [ $i -lt 50 ]; do
    [ "$(cat /sys/class/net/eth0/carrier 2>/dev/null)" = "1" ] && break
    i=$((i + 1))
    sleep 0.1
done

# Prefer dhcpcd when present (IPv6 SLAAC, DHCPv6, IPv4LL fallback);
# otherwise fall back to busybox udhcpc. Both run in the background so
# boot proceeds even when no DHCP server is reachable.
if command -v dhcpcd >/dev/null 2>&1; then
    dhcpcd -b eth0
else
    udhcpc -i eth0 -s /usr/share/udhcpc/default.script -b -t 5 -T 1 -A 3 &
fi
