#!/bin/sh
# Run mdnsd so this host answers <hostname>.local on the LAN. Reads
# service records from /etc/mdns.d/. Requires multicast on the network
# interface, which is the kernel default.

case "$1" in
    start)
        mdnsd
        ;;
    stop)
        killall mdnsd 2>/dev/null
        ;;
esac
