#!/bin/sh
# Bring sshd up on first boot. We do four things lazily here rather
# than baking them into the image:
#   1. Host keys — building them in would mean every flashed device
#      shares the same identity. Generate per-device on first boot.
#   2. Privilege separation user — sshd refuses to start without a
#      `sshd` user. We add one to /etc/passwd if missing.
#   3. /var/empty — the privsep chroot. sshd requires it to exist
#      with mode 755 owned by root.
#   4. Permissive sshd_config IF root has no password — the dev-image
#      ships root with an empty password for convenience, and sshd's
#      defaults (PermitRootLogin prohibit-password, PermitEmptyPasswords
#      no) refuse that combination. When root is intentionally
#      passwordless, follow that policy through to SSH; when root has
#      a real password (production images), keep sshd's strict defaults.
# All checks are idempotent, so subsequent boots are no-ops.

case "$1" in
    start)
        if ! ls /etc/ssh/ssh_host_*_key >/dev/null 2>&1; then
            ssh-keygen -A
        fi
        if ! grep -q "^sshd:" /etc/passwd 2>/dev/null; then
            echo 'sshd:x:22:22:sshd:/var/empty:/sbin/nologin' >> /etc/passwd
            echo 'sshd:x:22:' >> /etc/group
        fi
        mkdir -p /var/empty
        chmod 755 /var/empty
        # If root has an empty password hash in /etc/shadow (field 2 is
        # blank: `root::...`), enable permissive sshd options so that
        # passwordless root login over SSH works the same as on the
        # serial console. The marker line below is rewritten on each
        # boot to stay in sync with /etc/shadow if the operator later
        # sets a root password.
        if grep -q '^root::' /etc/shadow 2>/dev/null; then
            if ! grep -q '^# yoe-dev-permissive$' /etc/ssh/sshd_config 2>/dev/null; then
                {
                    echo ''
                    echo '# yoe-dev-permissive'
                    echo 'PermitRootLogin yes'
                    echo 'PermitEmptyPasswords yes'
                } >> /etc/ssh/sshd_config
            fi
        fi
        # sshd backgrounds itself when -D is omitted.
        /usr/sbin/sshd
        ;;
    stop)
        killall sshd 2>/dev/null
        ;;
esac
